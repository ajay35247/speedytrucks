JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
OTP_MAX_SEND_ATTEMPTS=5
OTP_MAX_VERIFY_ATTEMPTS=8
OTP_BLOCK_MINUTES=30
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
MOBILE_APP_URL_SCHEME=aptrucking://
SENTRY_DSN=
UPLOAD_STORAGE_MODE=disabled
S3_BUCKET=

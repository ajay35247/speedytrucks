# ─── SpeedyTrucks Platform .env ──────────────────────────────
# Copy this to .env and fill in your values

# ── Server ──────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
CLIENT_URL=https://aptrucking.in

# ── MongoDB (MongoDB Atlas recommended) ─────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/speedytrucks?retryWrites=true&w=majority
MONGO_ROOT_PASSWORD=your_secure_password

# ── Redis (Redis Cloud / Upstash recommended) ────────────────
REDIS_URL=redis://default:<password>@<host>:<port>
REDIS_PASSWORD=your_redis_password

# ── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_super_secret_access_key_min_32_chars_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ── Twilio (SMS OTP + WhatsApp) ───────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=+14155238886

# ── Cloudinary (Document / KYC / Image uploads) ───────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Razorpay (Payments + Payouts) ─────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Email (Gmail SMTP / SendGrid) ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@aptrucking.in
SMTP_PASS=your_app_password
EMAIL_FROM=SpeedyTrucks <noreply@aptrucking.in>

# ── Firebase (Push Notifications) ─────────────────────────────
FCM_SERVER_KEY=your_firebase_server_key

# ── Bcrypt ────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Frontend (Vite env vars) ──────────────────────────────────
VITE_API_URL=https://api.aptrucking.in/api
VITE_SOCKET_URL=https://api.aptrucking.in

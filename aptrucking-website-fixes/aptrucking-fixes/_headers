# ✅ Security Headers for aptrucking.in
# Upload this file to: frontend/public/_headers

/*
  # ✅ Force HTTPS
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # ✅ Prevent clickjacking (XFO)
  X-Frame-Options: SAMEORIGIN

  # ✅ Prevent XSS
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block

  # ✅ Referrer policy
  Referrer-Policy: strict-origin-when-cross-origin

  # ✅ Permissions policy
  Permissions-Policy: geolocation=(self), camera=(), microphone=()

  # ✅ Content Security Policy
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://speedytrucks-production.up.railway.app wss://speedytrucks-production.up.railway.app; frame-ancestors 'none';

  # ✅ Cross-Origin Opener Policy
  Cross-Origin-Opener-Policy: same-origin-allow-popups

# ✅ Cache static assets for 1 year
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# ✅ Cache icons
/icons/*
  Cache-Control: public, max-age=31536000, immutable

# ✅ Don't cache HTML (always fresh)
/*.html
  Cache-Control: no-cache, no-store, must-revalidate

# ✅ Cache manifest
/manifest.json
  Cache-Control: public, max-age=86400

# ✅ Cache service worker with short TTL
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
